* text=auto eol=lf

# Windows scripts keep CRLF for compatibility
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.jar binary
*.keystore binary
*.ttf binary
*.otf binary
